# Discord developer portal bot token. Keep this secret.
DISCORD_TOKEN=

# At least one user or role allowlist is required. Use comma-separated Discord IDs.
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_ROLE_IDS=

# Optional additional restrictions. Empty means any guild/channel for an allowed principal.
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=

OPENCODE_URL=http://localhost:4096
OPENCODE_PUBLIC_URL=http://localhost:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=
OPENCODE_AGENT=build

# Approve every OpenCode permission prompt once. Set false to reject prompts.
OPENCODE_AUTO_APPROVE=true
OPENCODE_TASK_TIMEOUT_MS=1800000
OPENCODE_ROUTING_TIMEOUT_MS=120000
JOB_POLL_INTERVAL_MS=10000
JOB_CONTINUE_INTERVAL_MS=60000

PROJECTS_FILE=./projects.json
JOBS_DATABASE=./jobs.sqlite
PROJECTS_ROOT=./projects
GIT_CLONE_TIMEOUT_MS=300000
