DISCORD_TOKEN=
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_ROLE_IDS=
DISCORD_ALLOWED_GUILD_IDS=
DISCORD_ALLOWED_CHANNEL_IDS=

OPENCODE_PORT=4096
# Public authentication-proxy URL used in Discord session links.
OPENCODE_PUBLIC_URL=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
OPENCODE_AGENT=build
# Optional OpenCode provider/model selection, for example openai/gpt-5.2.
OPENCODE_MODEL=
# Optional model variant, such as low, medium, high, or xhigh when supported.
OPENCODE_REASONING_EFFORT=
OPENCODE_AUTO_APPROVE=true
# Overall bot deadline. Provider-level five-minute limits are disabled by the container.
OPENCODE_TASK_TIMEOUT_MS=1800000
OPENCODE_ROUTING_TIMEOUT_MS=120000
JOB_POLL_INTERVAL_MS=10000
JOB_CONTINUE_INTERVAL_MS=60000

CODE_SERVER_PORT=8080

# Example for a separately managed Docker-in-Docker daemon:
# DOCKER_HOST=tcp://dind:2375

PROJECTS_FILE=/home/opencode/data/projects.json
JOBS_DATABASE=/home/opencode/data/jobs.sqlite
PROJECTS_ROOT=/home/opencode/workspace
GIT_CLONE_TIMEOUT_MS=300000

# Optional higher Context7 limits.
CONTEXT7_API_KEY=

# Supply credentials for at least one OpenCode provider, or mount existing OpenCode state.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
